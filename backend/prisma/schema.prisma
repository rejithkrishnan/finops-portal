generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Authentication ───────────────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  role         UserRole @default(VIEWER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

// ─── Environment Management ───────────────────────────────────────

model Application {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  description  String?
  icon         String?       // optional icon identifier
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  environments Environment[]

  @@map("applications")
}

model Environment {
  id            Int                @id @default(autoincrement())
  applicationId Int                @map("application_id")
  name          String
  shortCode     String             @map("short_code")
  description   String?
  envType       String             @map("env_type") // PROD, UAT, DEV, PT, FININQ, etc.
  siteType      String             @map("site_type") // DC, DR
  isActive      Boolean            @default(true) @map("is_active")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  application   Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  servers       Server[]
  databases     DatabaseInstance[]

  @@unique([applicationId, shortCode])
  @@map("environments")
}

model ServerRole {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  color       String   // hex color code
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  servers     Server[]

  @@map("server_roles")
}

model Server {
  id            Int         @id @default(autoincrement())
  environmentId Int         @map("environment_id")
  hostname      String
  ipAddress     String      @map("ip_address")
  roleId        Int         @map("role_id")
  os            String?
  cores         Int?
  memory        String?
  segment       String?
  isActive      Boolean     @default(true) @map("is_active")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  role          ServerRole  @relation(fields: [roleId], references: [id])

  @@map("servers")
}

model DatabaseInstance {
  id               Int         @id @default(autoincrement())
  environmentId    Int         @map("environment_id")
  name             String
  host             String
  port             Int
  dbType           String      @map("db_type") // Oracle, PostgreSQL, etc.
  version          String?
  schemaName       String?     @map("schema_name")
  connectionString String?     @map("connection_string")
  isActive         Boolean     @default(true) @map("is_active")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  environment      Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@map("database_instances")
}

model EnvType {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("env_types")
}
